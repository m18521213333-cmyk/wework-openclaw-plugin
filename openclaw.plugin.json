{
  "id": "wework-scrm",
  "name": "WeWork SCRM",
  "description": "企业微信 SCRM 插件 — 通过 Java 后端 WS 协议操控，与 Web 管理端共存",
  "version": "0.2.0",
  "author": "zhijiansmart",
  "configSchema": {
    "type": "object",
    "properties": {
      "javaWsUrl": {
        "type": "string",
        "default": "ws://127.0.0.1:15088",
        "description": "Java 后端 WebSocket 地址 (PC端协议端口)"
      },
      "storage": {
        "type": "object",
        "description": "本地数据存储配置",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["sqlite", "mysql"],
            "default": "sqlite",
            "description": "存储类型"
          },
          "sqlitePath": {
            "type": "string",
            "default": "./wework-scrm.db",
            "description": "SQLite 数据库路径"
          }
        }
      },
      "dify": {
        "type": "object",
        "description": "Dify AI 集成配置（可选）",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "apiUrl": {
            "type": "string",
            "description": "Dify API 地址"
          },
          "apiKey": {
            "type": "string",
            "description": "Dify API Key"
          }
        }
      }
    },
    "required": []
  }
}
